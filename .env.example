# HumenAI — Environment Variables (example)

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (projet créé via supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI Provider (Gemini — pour RAG embeddings text-embedding-004)
GEMINI_API_KEY=

# Cloudinary (images, vidéos, audio clients)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Channel API Keys (à remplir pour chaque canal connecté)
WHATSAPP_API_KEY=
INSTAGRAM_API_KEY=
MESSENGER_API_KEY=
TIKTOK_API_KEY=

# E-commerce Integrations
SHOPIFY_API_KEY=
WOOCOMMERCE_API_KEY=
